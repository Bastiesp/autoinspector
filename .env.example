# Puerto local. Render inyecta PORT automáticamente.
PORT=3000

# Opcional: si lo agregas, AutoInspector usará análisis con IA real.
# Si queda vacío, funcionará con un análisis básico basado en reglas.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Opcional: datos para contacto comercial
CONTACT_WHATSAPP=56912345678
CONTACT_EMAIL=contacto@autoinspector.cl
