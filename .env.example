# Servidor
PORT=3000
NODE_ENV=production

# OpenAI opcional. Si no lo configuras, AutoInspector genera un informe preventivo por reglas.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Cloudinary recomendado para guardar fotos comprimidas
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=autoinspector/inspections

# Límites de carga
MAX_UPLOAD_MB=3
MAX_FILES=24

# Contacto comercial/mecánico
CONTACT_WHATSAPP=56912345678
CONTACT_EMAIL=contacto@autoinspector.cl
MECHANIC_NAME=AutoInspector Mecánico
