# Servidor
PORT=3000
NODE_ENV=development

# OpenAI - opcional, para análisis con IA de texto + fotos
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Cloudinary - recomendado para guardar fotos de inspecciones
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=autoinspector/inspections

# Tamaño máximo aceptado por el servidor después de comprimir en el navegador
# Recomendado: 2 o 3 MB por foto comprimida
MAX_UPLOAD_MB=3

# Contacto comercial para revisión profesional
CONTACT_WHATSAPP=56912345678
CONTACT_EMAIL=contacto@autoinspector.cl
